{
  "name": "@cerberus-ai/core",
  "version": "3.0.1",
  "description": "Runtime security for AI agent tool execution. Detects, correlates, and interrupts guarded Lethal Trifecta attack paths.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ spec/ examples/",
    "lint:fix": "eslint src/ tests/ spec/ examples/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"spec/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"spec/**/*.ts\" \"examples/**/*.ts\"",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "demo:capture": "tsx examples/demo-capture.ts",
    "dsa-peas:validate": "tsx spec/dsa-peas/cli.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "ai-security",
    "agentic-ai",
    "prompt-injection",
    "data-exfiltration",
    "runtime-security",
    "llm-security",
    "cerberus"
  ],
  "author": "Six Sense Enterprise Services",
  "license": "MIT",
  "homepage": "https://cerberus.sixsenseenterprise.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Odingard/cerberus-core"
  },
  "bugs": {
    "url": "https://github.com/Odingard/cerberus-core/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@langchain/core": "^1.1.30",
    "@langchain/openai": "^1.2.12",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "openai": "^6.25.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
